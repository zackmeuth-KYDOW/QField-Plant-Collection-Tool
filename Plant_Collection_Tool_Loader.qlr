        <default expression="overlay_intersects('ky_county_boundaries', &quot;NAME&quot;)[0]" field="County" applyOnUpdate="0"/>
        <default expression="if(overlay_intersects('ky_snp_boundaries') OR overlay_intersects('ky_wma_boundaries') OR overlay_intersects('ky_state_park_boundaries') OR overlay_intersects('ky_state_forest_boundaries') OR overlay_intersects('ky_usfs_boundaries'), 'Public', 'Private')" field="Land_Ownership" applyOnUpdate="0"/>
        <default expression="raster_value('site_slope', 1, $geometry)" field="Slope" applyOnUpdate="0"/>
        <default expression="raster_value('site_aspect', 1, $geometry)" field="Aspect" applyOnUpdate="0"/>
        <default expression="" field="RecordedBy" applyOnUpdate="0"/>
