        <default expression="" field="fid" applyOnUpdate="0"/>
        <default expression="uuid()" field="OccurenceID" applyOnUpdate="0"/>
        <default expression="" field="EventDate" applyOnUpdate="0"/>
        <default expression="--Always using EPSG 3089 for the aspect &amp; slope math and because that is the native CRS for KyFromAbove data. Need to transform coordinates to decimal.degrees for DarwinCore.&#xa;&#xa;y(transform($geometry, 'EPSG:3089', 'EPSG:4326'))" field="DecimalLatitude" applyOnUpdate="0"/>
        <default expression="--Always using EPSG 3089 for the aspect &amp; slope math and because that is the native CRS for KyFromAbove data. Need to transform coordinates to decimal.degrees for DarwinCore.&#xa;&#xa;x(transform($geometry, 'EPSG:3089', 'EPSG:4326'))" field="DecimalLongitude" applyOnUpdate="0"/>
