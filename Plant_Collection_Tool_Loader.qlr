        <default field="IndividualCount" applyOnUpdate="0" expression=""/>
        <default field="Locality" applyOnUpdate="0" expression=""/>
        <default field="SoilType" applyOnUpdate="0" expression="overlay_intersects('site_soils', &quot;muname&quot;)[0]"/>
        <default field="Geology" applyOnUpdate="0" expression="overlay_intersects('site_geology', &quot;Geologic Unit Name&quot;)[0]"/>
